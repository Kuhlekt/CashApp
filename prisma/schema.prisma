// prisma/schema.prisma
// CashFlow Platform — Full SaaS Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ORGANISATIONS ────────────────────────────────────────────────────────────
model Org {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  plan            String    @default("trial")    // trial | starter | professional | enterprise
  status          String    @default("trial")    // trial | active | suspended | cancelled
  mrr             Int       @default(0)
  trialEndsAt     DateTime?
  stripeCustomerId String?  @unique
  stripeSubId     String?   @unique
  maxUsers        Int       @default(5)
  maxBatches      Int       @default(100)
  settings        Json?                          // org-level config overrides
  planSnapshot    Json?                          // snapshot of plan limits at signup (grandfathering)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users           User[]
  invites         Invite[]
  sessions        BatchSession[]
  accounts        Account[]
  openItems       OpenItem[]
  bankFiles       BankFile[]
  allocations     Allocation[]
  allocationLines AllocationLine[]
  onAccountItems  OnAccountItem[]
  reasonCodes     ReasonCode[]
  auditLogs       AuditLog[]
  automationConfig AutomationConfig?
  regions         Region[]
  automationRuns  AutomationRun[]
  mlRecords       MLRecord[]
  govRules        GovRules?
  notifConfig     NotificationConfig?
  erpExports      ErpExport[]

  @@index([slug])
  @@index([status])
}

// ─── USERS ────────────────────────────────────────────────────────────────────
model User {
  id              String    @id @default(cuid())
  orgId           String
  email           String    @unique
  name            String
  initials        String    @default("")
  phone           String?
  role            String    @default("accountant") // accountant | controller | admin | superadmin
  level           String    @default("L2")         // L1 | L2 | L3 | L4
  status          String    @default("active")     // active | suspended | invited | pending
  passwordHash    String?
  totpSecret      String?
  totpEnabled     Boolean   @default(false)
  resetToken      String?   @unique
  resetTokenExpiry DateTime?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  loginCount      Int       @default(0)
  failedLogins    Int       @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  auditLogs       AuditLog[]
  allocations     Allocation[]
  sentInvites     Invite[]  @relation("InvitedBy")

  @@index([orgId])
  @@index([email])
  @@index([resetToken])
}

// ─── INVITES ──────────────────────────────────────────────────────────────────
model Invite {
  id          String    @id @default(cuid())
  orgId       String
  email       String
  role        String    @default("accountant")
  token       String    @unique @default(cuid())
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([orgId])
  @@index([token])
  @@index([email])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  orgId       String
  sessionId   String?
  userId      String?
  category    String   // system | user | approve | security | api
  event       String
  message     String
  actor       String
  ipAddress   String?
  userAgent   String?
  extra       Json?
  prevHash    String   @default("0000000000000000")
  hash        String
  timestamp   DateTime @default(now())

  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, timestamp(sort: Desc)])
  @@index([orgId, category])
  @@index([sessionId])
  @@index([userId])
}

// ─── BATCH SESSIONS ───────────────────────────────────────────────────────────
model BatchSession {
  id            String    @id @default(cuid())
  orgId         String
  sessionRef    String    @unique
  status        String    @default("open")   // open | running | suspended | complete | archived
  trigger       String    @default("manual") // manual | scheduled | api
  userId        String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  suspendedAt   DateTime?
  suspendReason String?
  recordCount   Int       @default(0)
  matchedCount  Int       @default(0)
  exceptionCount Int      @default(0)
  totalValue    Decimal   @default(0) @db.Decimal(18, 2)
  region        String?
  meta          Json?

  org           Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  allocations   Allocation[]

  @@index([orgId, status])
  @@index([orgId, startedAt(sort: Desc)])
}

// ─── ACCOUNTS (DEBTORS) ───────────────────────────────────────────────────────
model Account {
  id              String   @id @default(cuid())
  orgId           String
  accountNumber   String
  name            String
  tradingName     String?
  abn             String?
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  country         String   @default("AU")
  postcode        String?
  creditLimit     Decimal? @db.Decimal(18, 2)
  paymentTerms    Int      @default(30)
  currency        String   @default("AUD")
  region          String?
  status          String   @default("active")
  sourceType      String   @default("manual")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org             Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  openItems       OpenItem[]
  allocations     Allocation[]

  @@unique([orgId, accountNumber])
  @@index([orgId])
  @@index([orgId, name])
}

// ─── OPEN ITEMS (INVOICES) ────────────────────────────────────────────────────
model OpenItem {
  id                String   @id @default(cuid())
  orgId             String
  accountId         String?
  invoiceNumber     String
  accountNumber     String?
  customerName      String?
  invoiceDate       DateTime?
  dueDate           DateTime?
  originalAmount    Decimal  @db.Decimal(18, 2)
  outstandingAmount Decimal  @db.Decimal(18, 2)
  currency          String   @default("AUD")
  region            String?
  status            String   @default("open") // open | partial | paid | disputed | written-off
  reference         String?
  poNumber          String?
  sourceType        String   @default("manual")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org               Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account           Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  allocationLines   AllocationLine[]

  @@index([orgId, status])
  @@index([orgId, accountNumber])
  @@index([orgId, invoiceNumber])
}

// ─── BANK FILES ───────────────────────────────────────────────────────────────
model BankFile {
  id           String   @id @default(cuid())
  orgId        String
  filename     String
  format       String   // mt940 | camt053 | bai2 | csv
  fileHash     String
  recordCount  Int      @default(0)
  totalCredits Decimal  @default(0) @db.Decimal(18, 2)
  currency     String   @default("AUD")
  region       String?
  processedAt  DateTime @default(now())
  sourceType   String   @default("manual")

  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@index([orgId])
  @@index([fileHash])
}

// ─── BANK TRANSACTIONS ────────────────────────────────────────────────────────
model BankTransaction {
  id            String   @id @default(cuid())
  bankFileId    String
  reference     String?
  valueDate     DateTime?
  amount        Decimal  @db.Decimal(18, 2)
  currency      String   @default("AUD")
  description   String?
  payer         String?
  status        String   @default("unmatched") // unmatched | matched | on-account | excluded
  matchMethod   String?  // ml | ai | manual | rule
  confidence    Decimal? @db.Decimal(5, 4)

  bankFile      BankFile @relation(fields: [bankFileId], references: [id], onDelete: Cascade)
  allocations   Allocation[]

  @@index([bankFileId])
  @@index([status])
}

// ─── ALLOCATIONS ──────────────────────────────────────────────────────────────
model Allocation {
  id              String   @id @default(cuid())
  orgId           String
  sessionId       String?
  accountId       String?
  transactionId   String?
  matchMethod     String   @default("manual")
  confidence      Decimal? @db.Decimal(5, 4)
  totalAmount     Decimal  @db.Decimal(18, 2)
  status          String   @default("pending") // pending | approved | rejected | posted
  approvedBy      String?
  approvedAt      DateTime?
  postedAt        DateTime?
  aiReasoning     String?
  userId          String?
  createdAt       DateTime @default(now())

  org             Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  session         BatchSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  account         Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transaction     BankTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  lines           AllocationLine[]

  @@index([orgId, status])
  @@index([sessionId])
  @@index([accountId])
}

// ─── ALLOCATION LINES ─────────────────────────────────────────────────────────
model AllocationLine {
  id            String   @id @default(cuid())
  orgId         String
  allocationId  String
  openItemId    String?
  amount        Decimal  @db.Decimal(18, 2)
  variance      Decimal  @default(0) @db.Decimal(18, 2)
  varianceCode  String?
  note          String?

  org           Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  allocation    Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  openItem      OpenItem?  @relation(fields: [openItemId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([allocationId])
}

// ─── ON ACCOUNT ITEMS ─────────────────────────────────────────────────────────
model OnAccountItem {
  id           String   @id @default(cuid())
  orgId        String
  reference    String
  payer        String?
  amount       Decimal  @db.Decimal(18, 2)
  currency     String   @default("AUD")
  reasonCode   String?
  note         String?
  status       String   @default("open") // open | matched | written-off
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
}

// ─── REASON CODES ─────────────────────────────────────────────────────────────
model ReasonCode {
  id      String @id @default(cuid())
  orgId   String
  code    String
  label   String
  type    String // variance | on-account

  org     Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, code, type])
  @@index([orgId])
}

// ─── GOVERNANCE RULES ─────────────────────────────────────────────────────────
model GovRules {
  id              String  @id @default(cuid())
  orgId           String  @unique
  minConfidence   Int     @default(85)
  requireApproval Decimal @default(50000) @db.Decimal(18, 2)
  dualApproval    Boolean @default(true)
  hashVerify      Boolean @default(true)
  autoArchive     Boolean @default(true)
  retentionDays   Int     @default(2555)
  flagPartial     Boolean @default(true)
  maxExceptionAge Int     @default(5)
  erpApproval     Boolean @default(true)

  org             Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// ─── AUTOMATION CONFIG ────────────────────────────────────────────────────────
model AutomationConfig {
  id                String   @id @default(cuid())
  orgId             String   @unique
  enabled           Boolean  @default(false)
  frequency         String   @default("daily")
  runTime           String   @default("06:00")
  timezone          String   @default("Australia/Sydney")
  batchOpenAction   String   @default("suspend")
  timeoutMin        Int      @default(30)
  mlAutoThresh      Decimal  @default(0.92) @db.Decimal(5, 4)
  mlAiThresh        Decimal  @default(0.75) @db.Decimal(5, 4)
  aiEnabled         Boolean  @default(true)
  aiModel           String   @default("claude-sonnet-4-20250514")
  aiMaxCallsPerRun  Int      @default(200)
  haltAtExceptions  Boolean  @default(true)
  autoApprove       Boolean  @default(false)
  autoOutput        Boolean  @default(true)
  notifyOnComplete  Boolean  @default(true)
  outputFormat      String   @default("sap-idoc")
  outputFilename    String   @default("CASHAPP_{date}_{region}_{seq}.txt")
  outputLocalCopy   Boolean  @default(true)
  config            Json?

  org               Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// ─── REGIONS ──────────────────────────────────────────────────────────────────
model Region {
  id          String  @id @default(cuid())
  orgId       String
  code        String
  name        String
  currency    String  @default("AUD")
  bankAccount String?
  active      Boolean @default(true)

  org         Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, code])
  @@index([orgId])
}

// ─── AUTOMATION RUNS ──────────────────────────────────────────────────────────
model AutomationRun {
  id            String   @id @default(cuid())
  orgId         String
  trigger       String   @default("scheduled")
  status        String   @default("running")
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  recordsIn     Int      @default(0)
  matched       Int      @default(0)
  exceptions    Int      @default(0)
  outputFile    String?
  error         String?
  log           Json?

  org           Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, startedAt(sort: Desc)])
}

// ─── ML RECORDS ───────────────────────────────────────────────────────────────
model MLRecord {
  id          String   @id @default(cuid())
  orgId       String
  payer       String
  reference   String?
  amount      Decimal  @db.Decimal(18, 2)
  invoiceNums String[]
  learnedAt   DateTime @default(now())

  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, payer])
}

// ─── NOTIFICATION CONFIG ──────────────────────────────────────────────────────
model NotificationConfig {
  id              String  @id @default(cuid())
  orgId           String  @unique
  enabled         Boolean @default(false)
  provider        String  @default("clicksend")
  fromName        String  @default("CashFlow AI")
  fromEmail       String?
  fromPhone       String?
  clicksendUser   String?
  clicksendKey    String? // encrypted
  emailAddressId  String?
  onBatchComplete Boolean @default(true)
  onException     Boolean @default(true)
  onApproval      Boolean @default(true)
  onErpExport     Boolean @default(true)

  org             Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// ─── ERP EXPORTS ──────────────────────────────────────────────────────────────
model ErpExport {
  id           String   @id @default(cuid())
  orgId        String
  sessionId    String?
  format       String   @default("sap-idoc")
  filename     String
  recordCount  Int      @default(0)
  totalValue   Decimal  @default(0) @db.Decimal(18, 2)
  status       String   @default("pending") // pending | approved | delivered | failed
  approvedBy   String?
  approvedAt   DateTime?
  deliveredAt  DateTime?
  error        String?
  createdAt    DateTime @default(now())

  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
}

// ─── RATE LIMIT ───────────────────────────────────────────────────────────────
model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique  // ip:endpoint or userId:endpoint
  count     Int      @default(1)
  windowEnd DateTime

  @@index([key])
  @@index([windowEnd])
}

// ─── WEBHOOK EVENTS ───────────────────────────────────────────────────────────
model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // stripe | clicksend
  eventType   String
  payload     Json
  processed   Boolean  @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@index([provider, processed])
  @@index([createdAt])
}

// ─── PRICING ENGINE ───────────────────────────────────────────────────────────
model Plan {
  id          String   @id @default(cuid())
  code        String   @unique  // starter | professional | enterprise
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  maxUsers    Int      @default(10)
  maxBatches  Int      @default(200)
  baseUsdMonth      Int     @default(0)   // base USD monthly price in cents (anchor for all currencies)
  baseUsdYear       Int     @default(0)   // base USD annual price in cents
  annualDiscountPct Int     @default(20)  // % discount applied to annual billing (editable per plan)
  features    Json     // array of feature strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prices      PlanPrice[]
}

model PlanPrice {
  id            String   @id @default(cuid())
  planId        String
  stripePriceId String?  @unique  // set after creating in Stripe
  currency      String   @default("AUD")  // AUD | USD | GBP | EUR | NZD
  interval      String   @default("month") // month | year
  amount        Int      // in cents
  discountPct   Int      @default(0)  // annual discount %
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  plan          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, currency, interval])
  @@index([planId])
  @@index([currency])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  stripeId      String?   // Stripe coupon/promo ID
  discountType  String    @default("percent")  // percent | fixed
  discountValue Int       // percent 0-100 or cents
  currency      String?   // null = applies to all
  maxRedemptions Int?
  redemptions   Int       @default(0)
  validFrom     DateTime  @default(now())
  validUntil    DateTime?
  active        Boolean   @default(true)
  planCodes     String[]  // empty = all plans
  createdAt     DateTime  @default(now())

  @@index([code])
  @@index([active])
}
